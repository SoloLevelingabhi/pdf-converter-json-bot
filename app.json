{
  "name": "PDF to JSON Converter Bot",
  "description": "Telegram bot to convert SSC exam PDFs to JSON format",
  "repository": "https://github.com/yourusername/pdf-converter-bot",
  "logo": "https://your-logo-url.com/logo.png",
  "keywords": ["telegram", "bot", "pdf", "json", "converter"],
  "env": {
    "API_ID": {
      "description": "Telegram API ID",
      "required": false
    },
    "API_HASH": {
      "description": "Telegram API Hash",
      "required": false
    },
    "BOT_TOKEN": {
      "description": "Bot token from @BotFather",
      "required": false
    },
    "MONGO_URI": {
      "description": "MongoDB connection URI",
      "required": false
    },
    "DATABASE_NAME": {
      "description": "Database name",
      "required": true,
      "value": "pdf_converter"
    },
    "OWNER_ID": {
      "description": "Your Telegram user ID",
      "required": true
    },
    "AGENTROUTER_API_KEY": {
      "description": "AgentRouter API key (get from https://agentrouter.org/console/token)",
      "required": true
    },
    "VISION_MODEL": {
      "description": "Vision model for PDF extraction (google/gemini-2.5-flash, google/gemini-2.5-pro)",
      "required": false,
      "value": "google/gemini-2.5-flash"
    },
    "LOG_LEVEL": {
      "description": "Logging level",
      "required": false,
      "value": "INFO"
    }
  },
  "buildpacks": [
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest.git"
    },
    {
      "url": "https://github.com/sunny4381/heroku-buildpack-poppler.git"
    },
    {
      "url": "heroku/python"
    }
  ],
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
