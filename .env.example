# Telegram Configuration
API_ID=1234567
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/
DATABASE_NAME=pdf_converter

# AgentRouter API Configuration (get key from https://agentrouter.org/console/token)
AGENTROUTER_API_KEY=sk-your_agentrouter_key_here
AGENTROUTER_BASE_URL=https://agentrouter.org/v1
# Vision models available: google/gemini-2.5-flash, google/gemini-2.5-pro, anthropic/claude-3-5-sonnet
VISION_MODEL=google/gemini-2.5-flash

# Bot Settings
OWNER_ID=123456789
LOG_LEVEL=INFO

# Feature Flags
ENABLE_OCR=false
ENABLE_CACHE=true
ENABLE_ANALYTICS=true
